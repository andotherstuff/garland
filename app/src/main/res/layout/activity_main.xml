<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_garland_window"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <LinearLayout
            style="@style/Widget.Garland.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="32dp">

            <ImageView
                android:id="@+id/logoView"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/garland_logo"
                android:visibility="gone" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/identity_section_label"
                android:textAppearance="@style/TextAppearance.Garland.SectionEyebrow" />

            <TextView
                android:id="@+id/mainStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:background="@drawable/bg_status_chip"
                android:paddingLeft="@dimen/garland_status_chip_padding_horizontal"
                android:paddingTop="@dimen/garland_status_chip_padding_vertical"
                android:paddingRight="@dimen/garland_status_chip_padding_horizontal"
                android:paddingBottom="@dimen/garland_status_chip_padding_vertical"
                android:text="Status"
                android:textAppearance="@style/TextAppearance.Garland.StatusChip"
                android:visibility="gone" />

            <TextView
                android:id="@+id/mainStatusHeadlineText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:gravity="center"
                android:text="Garland status headline"
                android:textAppearance="@style/TextAppearance.Garland.DisplayTitle" />

            <TextView
                android:id="@+id/mainStatusSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:gravity="center"
                android:text="@string/app_description"
                android:textAppearance="@style/TextAppearance.Garland.BodySupport" />

            <TextView
                android:id="@+id/mainNextStepsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:gravity="center"
                android:text="Next steps"
                android:textAppearance="@style/TextAppearance.Garland.BodySupport"
                android:visibility="gone" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:gravity="center"
                android:text="@string/app_boot_status"
                android:textAppearance="@style/TextAppearance.Garland.SupportLabel" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/garland_outline_soft" />

        <LinearLayout
            style="@style/Widget.Garland.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/primary_actions_label"
                android:textAppearance="@style/TextAppearance.Garland.SectionEyebrow" />

            <TextView
                android:id="@+id/actionSafetyNoteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:text="@string/primary_actions_note"
                android:textAppearance="@style/TextAppearance.Garland.BodySupport" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/configButton"
                    style="@style/Widget.Garland.ActionButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/config_button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createFileButton"
                    style="@style/Widget.Garland.ActionButton.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/garland_button_gap"
                    android:layout_weight="1"
                    android:text="@string/create_file_button" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/garland_outline_soft" />

        <LinearLayout
            style="@style/Widget.Garland.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/local_documents_label"
                android:textAppearance="@style/TextAppearance.Garland.SectionEyebrow" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:text="Tap a note to keep moving. Each row shows its latest local or upload state."
                android:textAppearance="@style/TextAppearance.Garland.BodySupport" />

            <LinearLayout
                android:id="@+id/documentListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:orientation="vertical" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/garland_outline_soft" />

        <LinearLayout
            style="@style/Widget.Garland.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_document_label"
                android:textAppearance="@style/TextAppearance.Garland.SectionEyebrow" />

            <TextView
                android:id="@+id/activeDocumentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:text="No note selected yet."
                android:textAppearance="@style/TextAppearance.Garland.SectionTitle" />

            <TextView
                android:id="@+id/activeDocumentDetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_tight_gap"
                android:text="Select a note from the list to review its latest state."
                android:textAppearance="@style/TextAppearance.Garland.BodySupport" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/garland_content_gap"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/retryUploadButton"
                    style="@style/Widget.Garland.ActionButton.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/retry_upload_button"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deleteDocumentButton"
                    style="@style/Widget.Garland.DangerButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/garland_button_gap"
                    android:layout_weight="1"
                    android:text="@string/delete_document_button"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/activeDocumentProgressLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/active_document_progress_label"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/activeDocumentProgressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <TextView
                android:id="@+id/activeDocumentDiagnosticsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Garland.DiagnosticsBody"
                android:visibility="gone" />

            <TextView
                android:id="@+id/activeDocumentUploadsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/active_document_uploads_label"
                android:visibility="gone" />

            <TextView
                android:id="@+id/activeDocumentUploadsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Garland.DiagnosticsBody"
                android:visibility="gone" />

            <TextView
                android:id="@+id/activeDocumentRelaysLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/active_document_relays_label"
                android:visibility="gone" />

            <TextView
                android:id="@+id/activeDocumentRelaysText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Garland.DiagnosticsBody"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
